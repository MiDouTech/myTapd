# ==============================
# Ticket Platform 测试环境发布配置
# 复制为 .env.test.local 后修改
# ==============================

# 是否自动启动本地基础设施（docker compose）
START_INFRA=true

# 是否在发布前执行 Maven 构建
BUILD_BACKEND=true

# Spring Profile
SPRING_PROFILE=test

# 应用端口
APP_PORT=8080

# MySQL 连接（用于 Spring Boot）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=ticket_platform_test
MYSQL_USER=root
MYSQL_PASSWORD=root123456

# 当 START_INFRA=true 时，用于 docker 内 mysql 初始化数据库
MYSQL_ROOT_PASSWORD=root123456

# Redis 连接
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# JWT 密钥（建议按公司规范更换）
JWT_SECRET=miduo-ticket-platform-jwt-secret-key-2026-must-be-long-enough

# 企微基础配置（必填后才可用企微能力）
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_CONTACT_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=
WECOM_TRUSTED_DOMAIN=

# 是否启用 RabbitMQ 消费企微回调（默认关闭，走本地异步）
WECOM_MQ_ENABLED=false

# 运行目录（PID、日志）
RUN_BASE_DIR=.run
