# ==============================
# Ticket Platform 测试环境发布配置
# 复制为 .env.test.local 后修改
# 敏感配置已迁移至 Nacos，详见 miduo-md/nacos-config/README.md
# ==============================

# 是否自动启动本地基础设施（docker compose）
START_INFRA=true

# 是否在发布前执行 Maven 构建
BUILD_BACKEND=true

# Spring Profile
SPRING_PROFILE=test

# 应用端口
APP_PORT=8080

# MySQL 连接（用于本地 docker 初始化）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=ticket_platform_test
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me

# Redis 连接
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# Nacos 配置中心
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=test
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# 企微基础配置（已迁移至 Nacos）
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_CONTACT_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=
WECOM_TRUSTED_DOMAIN=

# 是否启用 RabbitMQ 消费企微回调（默认关闭，走本地异步）
WECOM_MQ_ENABLED=false

# 运行目录（PID、日志）
RUN_BASE_DIR=.run
