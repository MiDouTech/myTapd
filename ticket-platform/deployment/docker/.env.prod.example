# ============================================================
# 生产环境变量模板
# 执行：cp .env.prod.example .env.prod，然后填写所有值
# 注意：.env.prod 绝对不能提交到 git
# ============================================================

# ── GHCR 镜像配置 ───────────────────────────────────────────
# 你的 GitHub 用户名或组织名（小写）
GHCR_OWNER=MiDouTech
# 部署的镜像标签：latest 或具体版本如 v1.2.0
IMAGE_TAG=latest

# ── MySQL（内网已有实例，填写内网 IP 或域名）──────────────
DB_HOST=10.0.4.4
DB_PORT=3306
# 只需要提前建好这个库，表由 Flyway 自动创建
DB_NAME=ticket_platform
DB_USERNAME=your_mysql_user
DB_PASSWORD=your_mysql_password

# ── Redis（内网已有实例，有密码）─────────────────────────
REDIS_HOST=10.0.3.135
REDIS_PORT=6379
REDIS_PASSWORD=MDrds_bl!2025

# ── JWT ─────────────────────────────────────────────────────
# 至少 64 位随机字符串，保密
JWT_SECRET=change_me_jwt_secret_key_must_be_at_least_64_characters_long_here

# ── MinIO（由 docker-compose 管理）────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
# 如果使用外部 MinIO，取消注释并填写：
# MINIO_ENDPOINT=http://192.168.x.x:9000

# ── WeChat Work（企微）— 不用可留空 ────────────────────────
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_CONTACT_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=
WECOM_TRUSTED_DOMAIN=
WECOM_MQ_ENABLED=false

# ── 前端监听端口 ────────────────────────────────────────────
FRONTEND_PORT=80

# ── Watchtower 自动更新间隔（秒）──────────────────────────
# 300 = 每 5 分钟检查一次 GHCR 是否有新镜像
WATCHTOWER_POLL_INTERVAL=300
