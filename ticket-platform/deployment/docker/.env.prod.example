# ============================================================
# 生产环境变量模板
# 执行：cp .env.prod.example .env.prod，然后填写所有值
# 注意：.env.prod 绝对不能提交到 git
# ============================================================

# ── GHCR 镜像配置 ───────────────────────────────────────────
# 你的 GitHub 用户名或组织名（小写）
GHCR_OWNER=MiDouTech
# 部署的镜像标签：latest 或具体版本如 v1.2.0
IMAGE_TAG=latest

# ── Nacos 配置中心 ──────────────────────────────────────────
# 敏感配置已迁移至 Nacos，请确保 Nacos 中已导入对应环境的配置
# 详见 miduo-md/nacos-config/README.md
NACOS_SERVER_ADDR=your-nacos-server:8848
NACOS_NAMESPACE=prod
NACOS_USERNAME=nacos
NACOS_PASSWORD=change_me_nacos_password

# ── MinIO（由 docker-compose 管理）────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

# ── 前端监听端口 ────────────────────────────────────────────
FRONTEND_PORT=80

# ── Watchtower 自动更新间隔（秒）──────────────────────────
# 300 = 每 5 分钟检查一次 GHCR 是否有新镜像
WATCHTOWER_POLL_INTERVAL=300
