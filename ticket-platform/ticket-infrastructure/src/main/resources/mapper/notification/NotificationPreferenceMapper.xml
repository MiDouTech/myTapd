<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.miduo.cloud.ticket.infrastructure.persistence.mybatis.notification.mapper.NotificationPreferenceMapper">

    <select id="selectByUserId" parameterType="java.lang.Long"
            resultType="com.miduo.cloud.ticket.infrastructure.persistence.mybatis.notification.po.NotificationPreferencePO">
        SELECT id, user_id, event_type, site_enabled, wecom_enabled, email_enabled,
               create_time, update_time, create_by, update_by, deleted
        FROM notification_preference
        WHERE user_id = #{userId}
          AND deleted = 0
    </select>

</mapper>
