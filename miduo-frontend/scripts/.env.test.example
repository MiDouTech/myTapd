# ==============================
# 前端测试环境发布配置
# 复制为 .env.test.local 后修改
# ==============================

# 是否先安装依赖（推荐 true）
INSTALL_DEPS=true

# 构建模式（Vite）
BUILD_MODE=production

# 输出目录（默认 dist）
DIST_DIR=dist

# 若填写则构建后自动覆盖到该目录（例如 /data/www/ticket-frontend-test）
DEPLOY_DIR=

# -------- Vite 环境变量（会注入前端构建） --------
VITE_APP_TITLE=米多工单系统（测试环境）
VITE_API_BASE_URL=http://127.0.0.1:8080/api
VITE_USE_PROXY=false
VITE_API_PROXY_TARGET=

# 可通过 ticket-platform/scripts/gen-wecom-oauth-url.sh 生成
VITE_WECOM_OAUTH_URL=
