# ──────────────────────────────────────────────────────────────────────────────
# .deploy/config.env  –  所有可变构建配置集中在此，workflow 不硬编码任何项目值
# ──────────────────────────────────────────────────────────────────────────────

# 构建类型：java | dotnet
BUILD_TYPE=java

# Java 项目：JDK 版本（BUILD_TYPE=java 时生效）
JAVA_VERSION=8

# Java 项目：Maven 启动模块（使用 -pl 参数，留空则构建整个项目）
BUILD_SUBPROJECT=ticket-bootstrap

# .NET 项目：SDK 版本（BUILD_TYPE=dotnet 时取消注释并填写）
# DOTNET_VERSION=8.0

# CNB 制品库路径（不含域名 docker.cnb.cool/ 前缀，也不含镜像名）
# 示例：myorg/myproject/docker_images
CNB_NAMESPACE=miduoyanfa/middleground/my_mttapd

# CNB 版本记录仓库完整 HTTPS URL（用于写入 .cnbVersion.yml）
CNB_VERSION_REPO=https://cnb.cool/miduoyanfa/middleground/my_mttapd

# ── 前端静态包配置（留空则跳过前端打包） ─────────────────────────────────────
# 前端源码目录（相对于仓库根目录）
FRONTEND_DIR=miduo-frontend
# Node.js 版本
NODE_VERSION=20
# 生成的 ZIP 文件名前缀（最终产物：<名称>.zip）
FRONTEND_ARTIFACT_NAME=ticket-platform-frontend
